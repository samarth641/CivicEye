# Database (Aiven MySQL — use sslaccept=strict on Linux/Vercel if certs validate)
DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/defaultdb?sslaccept=strict"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Google Maps (enable Maps JavaScript API, Places, Geocoding, and create a Map ID for Advanced Markers)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="AIzaSyBSDUKaD9z0rmNxcD8B4Au5wpE3VjpSIzg"
NEXT_PUBLIC_GOOGLE_MAP_ID="AIzaSyBSDUKaD9z0rmNxcD8B4Au5wpE3VjpSIzg"

# Use "leaflet" for free OpenStreetMap when Google quota/billing is exceeded
NEXT_PUBLIC_MAP_PROVIDER=leaflet

# Cloudinary (optional, for report images)
NEXT_PUBLIC_CLOUDINARY_UPLOAD_URL="https://api.cloudinary.com/v1_1/YOUR_CLOUD_NAME/image/upload"
CLOUDINARY_UPLOAD_PRESET=""
